---
import { Image } from "astro:assets";
import FullLogo from "../images/logoFull.jpg";
import HamburgerMenu from "../components/HamburgerMenu.jsx";
---

<header>
  <nav class="navContainer">
    <div class="logoContainer">
      <Image src={FullLogo} alt="logo" class="logoImg" />
    </div>
    <ul class="navigation">
      <li>
        <ul class="mainNav">
          <!-- This component is loaded on the client side, becuase it has additional logic in js -->
          <HamburgerMenu client:load />
          <div class="navLinks">
            <li><a href="/">Home Page</a></li>
            <li><a href="/about">About Us</a></li>
            <li><a href="/gallery">Gallery</a></li>
          </div>
        </ul>
      </li>
      <li>
        <ul class="tickets">
          <li><a href="/tickets">Get Tickets</a></li>
        </ul>
      </li>
    </ul>
  </nav>
</header>

<div class="hidden" id="menuOverlay">
  <div class="menu-content">
    <nav>
      <a href="#">The Tournament</a>
      <a href="#">Format and Teams</a>
      <a href="#">FAQs</a>
      <a href="#">Partner</a>
    </nav>
  </div>
</div>

<script>
  const openButton = document.querySelector(".hamburgerMenu");
  const closeButton = document.getElementById("closeMenu");
  const menuOverlay = document.getElementById("menuOverlay");
  const header = document.querySelector(".navContainer") as HTMLDivElement;
  const body = document.querySelector("body") as HTMLBodyElement;

  openButton?.addEventListener("click", () => {
    menuOverlay?.classList.toggle("active");
    if (menuOverlay) {
      menuOverlay.style.top = `${header?.offsetHeight}px`;
    }
    if (menuOverlay?.classList.contains("active")) {
      body.style.overflow = "hidden";
    } else {
      body.style.overflow = "auto";
    }
  });
</script>
