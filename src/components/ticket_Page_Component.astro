---
import  TicketHero from '../components/TicketHero.astro';
import { Image } from 'astro:assets'
import FullLogo from '../images/logoFull.jpg';
import SmallLogo from '../images/logoSmall.png';
import Ticket1 from '../images/ticket_image1.jpg';
import Ticket2 from '../images/ticket_image2.jpg';
import Ticket3 from '../images/ticket_image3.jpg';
import '../styles/ticketsPage.css'

---

<span class="ticketHeading">Types of tickets:</span>
<div class="ticketImages">
    <div class = "ticketImage">
        <div class="ticketWrapper">
            <Image src={Ticket1} alt="ticket1" />
            <p class="moreInfo">More Info</p>
        </div>  
        <p class="ticketName">1 Day Ticket</p>
        <p class="ticketPrice">$65</p>
    </div>
    <div class = "ticketImage">
        <div class="ticketWrapper">
            <Image src={Ticket2} alt="ticket2" />
            <p class="moreInfo">More Info</p>
        </div>  
        <p class="ticketName">3 Day Ticket</p>
        <p class="ticketPrice">$109</p>
    </div>
    <div class = "ticketImage">
        <div class="ticketWrapper">
            <Image src={Ticket3} alt="ticket3" />
            <p class="moreInfo">More Info</p>
        </div>  
        <p class="ticketName">Fan Zone Ticket</p>
        <p class="ticketPrice">$309</p>
    </div>
</div>
