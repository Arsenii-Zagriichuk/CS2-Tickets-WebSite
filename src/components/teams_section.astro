---
import { Image } from 'astro:assets'
import g2 from '../images/g2.png'
import faze from '../images/faze.png'
import navi from '../images/navi.png'
import astralis from '../images/astralis.png'
import pain from '../images/pain.png'
import furia from '../images/furia.png'
import mouz from '../images/mouz.png'
import spirit from '../images/spirit.png'
import flyquest from '../images/flyquest.png'
import imperial from '../images/imperial.png'
import liquid from '../images/liquid.png'
import vitality from '../images/vitality.png'
import falcons from '../images/falcons.png'
import mongolz from '../images/mongolz.png'
import b8 from '../images/b8.png'
import eternalFire from '../images/eternalFire.png'
const firstRow = [
    { src: g2, alt: "g2", name: "G2 Esports" },
    { src: faze, alt: "faze", name: "Faze Clan" },
    { src: navi, alt: "navi", name: "Navi" },
    { src: astralis, alt: "astralis", name: "Astralis" },
    { src: pain, alt: "pain", name: "Pain" },
    { src: furia, alt: "furia", name: "Furia" },
    { src: mouz, alt: "mouz", name: "Mouz" },
    { src: spirit, alt: "spirit", name: "Spirit" },
];
const secondRow = [
    { src: flyquest, alt: "flyquest", name: "FlyQuest" },
    { src: imperial, alt: "imperial", name: "Imperial" },
    { src: liquid, alt: "liquid", name: "Liquid" },
    { src: vitality, alt: "vitality", name: "Vitality" },
    { src: falcons, alt: "falcons", name: "Falcons" },
    { src: mongolz, alt: "mongolz", name: "Mongolz" },
    { src: b8, alt: "b8", name: "B8" },
    { src: eternalFire, alt: "eternalFire", name: "Eternal Fire" },
];
import '../styles/teamsSection.css'
---
<section class="teams">
    <div class="container">
        <div class="top_text">
            <span>Teams invited</span>
            <span>Play off: 27-29 June</span>
        </div>
        
        <div class="firstRow">
            {firstRow.map((team) => (
                <div class="team-item">
                    <Image src={team.src} alt={team.alt} />
                    <span>{team.name}</span>
                </div>
            ))}
        </div>

        <div class="secondRow">
            {secondRow.map((team) => (
                <div class="team-item">
                    <Image src={team.src} alt={team.alt} />
                    <span>{team.name}</span>
                </div>
            ))}
        </div>
    </div>
</section>
